<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base app theme — Compose handles the actual theming.
         This XML theme is used for the splash/launch phase before Compose takes over. -->
    <style name="Theme.DeepSeekView" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>